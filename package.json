{
  "name": "pokerreads",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare preview",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply pokerreads-db --local",
    "db:migrate:staging": "wrangler d1 migrations apply pokerreads-db-staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply pokerreads-db --remote",
    "i18n:check": "node scripts/check-translations.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@serwist/next": "^9.5.7",
    "@serwist/precaching": "^9.5.7",
    "@serwist/sw": "^9.5.7",
    "better-auth": "^1.6.9",
    "idb": "^8.0.3",
    "lucide-react": "^1.11.0",
    "next": "^15.5.15",
    "next-intl": "^4.9.1",
    "pokersolver": "^2.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serwist": "^9.5.7",
    "stripe": "^17.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@opennextjs/cloudflare": "^1.19.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.2",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
